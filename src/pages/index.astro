---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const githubRepo = 'https://github.com/git-narwhal/GitNarwhal';
const releasesUrl = `${githubRepo}/releases`;

const features = [
  {
    icon: '🌊',
    title: 'Cross-Platform',
    desc: 'Runs natively on Windows, macOS, and Linux — including ARM64. One tool for every machine.',
  },
  {
    icon: '🔀',
    title: 'Full Git Operations',
    desc: 'Commit, push, pull, merge, rebase, stash, cherry-pick, reset, revert, and tag — all from a clean UI.',
  },
  {
    icon: '🎨',
    title: 'Themeable',
    desc: 'Ships with Nord (dark) and Gray (light) themes. Drop any FlatLaf-compatible .theme.json into ~/.gitnarwhal/themes/ for instant hot-reload.',
  },
  {
    icon: '📑',
    title: 'Multi-Repo Tabs',
    desc: 'Open multiple repositories in tabs. Drag to reorder, middle-click to close, tabs restore on next launch.',
  },
  {
    icon: '📊',
    title: 'Commit Graph',
    desc: 'Visualize your branch history at a glance with the built-in commit graph renderer.',
  },
  {
    icon: '🔓',
    title: 'Open Source',
    desc: 'MIT-licensed and built in the open. Contributions welcome — fork it, hack it, ship it.',
  },
];

const platforms = [
  { name: 'Windows x64',   icon: '🪟', tag: 'windows-x64'   },
  { name: 'Windows ARM64', icon: '🪟', tag: 'windows-arm64'  },
  { name: 'macOS x64',     icon: '🍎', tag: 'mac-x64'        },
  { name: 'macOS ARM64',   icon: '🍎', tag: 'mac-arm64'      },
  { name: 'Linux x64',     icon: '🐧', tag: 'linux-x64'      },
  { name: 'Linux ARM64',   icon: '🐧', tag: 'linux-arm64'    },
];
---

<Layout>
  <style>
    /* ── NAV ── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(46, 52, 64, 0.92);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--bg3);
      padding: 0 2rem;
    }
    .nav-inner {
      max-width: var(--max-w);
      margin: 0 auto;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--fg);
      text-decoration: none;
    }
    .nav-logo img { width: 32px; height: 32px; border-radius: 6px; }
    .nav-links { display: flex; gap: 1.5rem; }
    .nav-links a { color: var(--fg2); font-size: 0.9rem; }
    .nav-links a:hover { color: var(--fg); text-decoration: none; }
    .nav-gh {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--bg2);
      border: 1px solid var(--bg3);
      border-radius: 6px;
      padding: 5px 12px;
      color: var(--fg2) !important;
      font-size: 0.85rem;
      transition: border-color 0.2s;
    }
    .nav-gh:hover { border-color: var(--accent); color: var(--fg) !important; }

    /* ── HERO ── */
    .hero {
      padding: 7rem 2rem 5rem;
      text-align: center;
      background: radial-gradient(ellipse at 50% 0%, rgba(136,192,208,0.08) 0%, transparent 70%);
    }
    .hero-logo {
      width: 120px;
      height: 120px;
      border-radius: 24px;
      margin: 0 auto 2rem;
      display: block;
      box-shadow: 0 8px 40px rgba(0,0,0,0.4);
    }
    .hero h1 {
      font-size: clamp(2.4rem, 5vw, 3.6rem);
      font-weight: 800;
      color: var(--fg);
      letter-spacing: -0.02em;
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .hero h1 span { color: var(--accent); }
    .hero p {
      font-size: 1.2rem;
      color: var(--fg2);
      max-width: 560px;
      margin: 0 auto 2.5rem;
    }
    .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 0.75rem 1.75rem;
      border-radius: var(--radius);
      font-size: 1rem;
      font-weight: 600;
      transition: filter 0.2s, transform 0.1s;
      text-decoration: none !important;
    }
    .btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn-primary { background: var(--accent); color: var(--bg); }
    .btn-secondary { background: var(--bg2); color: var(--fg); border: 1px solid var(--bg3); }
    .badge {
      display: inline-block;
      background: var(--bg3);
      color: var(--fg2);
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 4px;
      margin-bottom: 1.2rem;
    }

    /* ── SECTION SHARED ── */
    section { padding: 5rem 2rem; }
    .container { max-width: var(--max-w); margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 3rem; }
    .section-header h2 { font-size: 2rem; font-weight: 700; color: var(--fg); margin-bottom: 0.5rem; }
    .section-header p { color: var(--fg2); max-width: 520px; margin: 0 auto; }

    /* ── FEATURES ── */
    .features { background: var(--bg2); }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .feature-card {
      background: var(--bg);
      border: 1px solid var(--bg3);
      border-radius: var(--radius);
      padding: 1.75rem;
      transition: border-color 0.2s, transform 0.2s;
    }
    .feature-card:hover { border-color: var(--accent2); transform: translateY(-2px); }
    .feature-icon { font-size: 2rem; margin-bottom: 0.75rem; }
    .feature-card h3 { color: var(--fg); font-size: 1.1rem; margin-bottom: 0.4rem; }
    .feature-card p { font-size: 0.95rem; color: var(--fg2); }

    /* ── SCREENSHOT SECTION ── */
    .screenshot-section { background: var(--bg); }
    .screenshot-mockup {
      background: var(--bg2);
      border: 1px solid var(--bg3);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
      max-width: 860px;
      margin: 0 auto;
    }
    .mockup-titlebar {
      background: var(--bg3);
      padding: 10px 14px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .dot { width: 12px; height: 12px; border-radius: 50%; }
    .dot-red   { background: var(--red); }
    .dot-amber { background: var(--orange); }
    .dot-green { background: var(--green); }
    .mockup-body {
      display: grid;
      grid-template-columns: 220px 1fr;
      min-height: 480px;
    }
    .mockup-sidebar {
      background: var(--bg2);
      border-right: 1px solid var(--bg3);
      padding: 1rem;
    }
    .mockup-sidebar h4 { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg3); margin-bottom: 0.75rem; }
    .branch-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 6px 8px;
      border-radius: 6px;
      font-size: 0.85rem;
      color: var(--fg2);
      margin-bottom: 2px;
    }
    .branch-item.active { background: rgba(136,192,208,0.15); color: var(--accent); }
    .branch-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
    .branch-dot.purple { background: var(--purple); }
    .branch-dot.green  { background: var(--green);  }
    .mockup-main { padding: 1rem; }
    .commit-row {
      display: grid;
      grid-template-columns: 28px 1fr 90px 80px;
      gap: 0.5rem;
      align-items: center;
      padding: 8px 6px;
      border-radius: 6px;
      font-size: 0.8rem;
      color: var(--fg2);
      border-bottom: 1px solid rgba(76,86,106,0.3);
    }
    .commit-row:hover { background: rgba(255,255,255,0.04); }
    .commit-dot-wrap { display: flex; justify-content: center; }
    .c-dot { width: 10px; height: 10px; border-radius: 50%; }
    .c-dot.a { background: var(--accent); }
    .c-dot.p { background: var(--purple); }
    .c-dot.g { background: var(--green); }
    .commit-msg { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--fg); }
    .commit-author { color: var(--fg3); font-size: 0.75rem; }
    .commit-sha { font-family: monospace; font-size: 0.75rem; color: var(--accent2); }

    /* ── DOWNLOAD ── */
    .download-section { background: var(--bg2); }
    .platform-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 2rem;
    }
    .platform-card {
      background: var(--bg);
      border: 1px solid var(--bg3);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--fg);
      font-size: 0.95rem;
      font-weight: 500;
      transition: border-color 0.2s;
      text-decoration: none !important;
    }
    .platform-card:hover { border-color: var(--accent); color: var(--fg); }
    .platform-icon { font-size: 1.5rem; }
    .download-note { text-align: center; color: var(--fg3); font-size: 0.9rem; }
    .download-note a { color: var(--accent2); }

    /* ── OPEN SOURCE CALLOUT ── */
    .oss-section { background: var(--bg); }
    .oss-card {
      background: linear-gradient(135deg, rgba(136,192,208,0.06), rgba(129,161,193,0.06));
      border: 1px solid var(--accent2);
      border-radius: 16px;
      padding: 3rem;
      text-align: center;
      max-width: 680px;
      margin: 0 auto;
    }
    .oss-card h2 { font-size: 1.8rem; color: var(--fg); margin-bottom: 1rem; }
    .oss-card p { color: var(--fg2); margin-bottom: 2rem; }

    /* ── FOOTER ── */
    footer {
      background: var(--bg);
      border-top: 1px solid var(--bg3);
      padding: 2rem;
      text-align: center;
      color: var(--fg3);
      font-size: 0.85rem;
    }
    footer a { color: var(--fg3); }
    footer a:hover { color: var(--accent); }
  </style>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a class="nav-logo" href={base}>
        <img src={`${base}icon.png`} alt="GitNarwhal logo" />
        GitNarwhal
      </a>
      <div class="nav-links">
        <a href="#features">Features</a>
        <a href="#download">Download</a>
        <a href={githubRepo} class="nav-gh" target="_blank" rel="noopener">
          <!-- GitHub icon inline SVG -->
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
              .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
              -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0
              1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82
              1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01
              1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="badge">Open Source · Cross-Platform · Free</div>
    <img src={`${base}icon.png`} alt="GitNarwhal" class="hero-logo" />
    <h1>Git, but <span>narwhal-powered</span></h1>
    <p>A modern, cross-platform Git GUI client. Open multiple repos in tabs, visualize history, and run every Git operation without touching the terminal.</p>
    <div class="hero-actions">
      <a href="#download" class="btn btn-primary">
        ⬇ Download
      </a>
      <a href={githubRepo} class="btn btn-secondary" target="_blank" rel="noopener">
        View on GitHub
      </a>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <h2>Everything you need for Git</h2>
        <p>From everyday commits to advanced history manipulation, GitNarwhal has you covered.</p>
      </div>
      <div class="features-grid">
        {features.map(f => (
          <div class="feature-card">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOT / MOCKUP -->
  <section class="screenshot-section">
    <div class="container">
      <div class="section-header">
        <h2>Clean, familiar interface</h2>
        <p>A native desktop feel powered by Swing + FlatLaf — fast, lightweight, no Electron.</p>
      </div>
      <div class="screenshot-mockup">
        <div class="mockup-titlebar">
          <div class="dot dot-red"></div>
          <div class="dot dot-amber"></div>
          <div class="dot dot-green"></div>
        </div>
        <div class="mockup-body">
          <div class="mockup-sidebar">
            <h4>Branches</h4>
            <div class="branch-item active"><div class="branch-dot"></div> main</div>
            <div class="branch-item"><div class="branch-dot purple"></div> feature/ui-revamp</div>
            <div class="branch-item"><div class="branch-dot green"></div> fix/commit-graph</div>
            <div class="branch-item"><div class="branch-dot"></div> release/0.1.0</div>
            <br/>
            <h4>Remotes</h4>
            <div class="branch-item"><div class="branch-dot"></div> origin/main</div>
          </div>
          <div class="mockup-main">
            {[
              { cls: 'a', msg: 'feat: add stash panel to sidebar',        author: 'celeste',  sha: 'a1b2c3d' },
              { cls: 'p', msg: 'fix: resolve merge conflict in Git.kt',   author: 'celeste',  sha: 'e4f5a6b' },
              { cls: 'g', msg: 'refactor: lazy-init Git companion object', author: 'celeste', sha: '7c8d9e0' },
              { cls: 'a', msg: 'ci: add ARM64 targets to build matrix',    author: 'celeste', sha: 'f1a2b3c' },
              { cls: 'p', msg: 'chore: bump FlatLaf 3.5.3 → 3.5.4',      author: 'celeste',  sha: '4d5e6f7' },
              { cls: 'g', msg: 'feat: hot-reload themes via updateUI()',   author: 'celeste',  sha: '8a9b0c1' },
            ].map(r => (
              <div class="commit-row">
                <div class="commit-dot-wrap"><div class={`c-dot ${r.cls}`}></div></div>
                <div class="commit-msg">{r.msg}</div>
                <div class="commit-author">{r.author}</div>
                <div class="commit-sha">{r.sha}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DOWNLOAD -->
  <section class="download-section" id="download">
    <div class="container">
      <div class="section-header">
        <h2>Download GitNarwhal</h2>
        <p>Available for every major platform. Grab the right build for your machine.</p>
      </div>
      <div class="platform-grid">
        {platforms.map(p => (
          <a href={`${releasesUrl}/latest`} class="platform-card" target="_blank" rel="noopener">
            <span class="platform-icon">{p.icon}</span>
            <span>{p.name}</span>
          </a>
        ))}
      </div>
      <p class="download-note">
        All builds are available on the <a href={releasesUrl} target="_blank" rel="noopener">GitHub Releases page</a>.
        Requires Java 21+ (bundled in the installer).
      </p>
    </div>
  </section>

  <!-- OSS CALLOUT -->
  <section class="oss-section">
    <div class="container">
      <div class="oss-card">
        <h2>Built in the open</h2>
        <p>GitNarwhal is MIT-licensed. Star the repo, file an issue, send a PR — every contribution matters.</p>
        <a href={githubRepo} class="btn btn-primary" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
              .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
              -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0
              1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82
              1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01
              1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <p>
      GitNarwhal is open source, <a href={`${githubRepo}/blob/main/LICENSE`} target="_blank" rel="noopener">MIT licensed</a>.
      &nbsp;·&nbsp;
      <a href={githubRepo} target="_blank" rel="noopener">GitHub</a>
      &nbsp;·&nbsp;
      <a href={`${githubRepo}/issues`} target="_blank" rel="noopener">Issues</a>
      &nbsp;·&nbsp;
      <a href={`${githubRepo}/releases`} target="_blank" rel="noopener">Releases</a>
    </p>
  </footer>
</Layout>
